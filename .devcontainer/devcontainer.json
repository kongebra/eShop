{
  "name": "eShop Workshop (.NET Aspire)",
  "image": "mcr.microsoft.com/devcontainers/dotnet:10.0",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb",
    "storage": "32gb"
  },

  "forwardPorts": [19888, 5221, 5222, 5223, 5224, 5226, 5243],
  "portsAttributes": {
    "19888": {
      "label": "Aspire Dashboard",
      "onAutoForward": "openPreview"
    },
    "5221": { "label": "Basket API" },
    "5222": { "label": "Catalog API" },
    "5223": { "label": "Identity API (http)" },
    "5224": { "label": "Ordering API" },
    "5226": { "label": "Payment Processor" },
    "5243": { "label": "Identity API (https)" }
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.csharp",
        "ms-azuretools.vscode-containers",
        "github.copilot",
        "github.copilot-chat",
        "github.vscode-pull-request-github",
        "ms-playwright.playwright"
      ],
      "settings": {
        "dotnet.defaultSolution": "eShop.Web.slnf",
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true
      }
    }
  },

  "remoteUser": "vscode"
}
